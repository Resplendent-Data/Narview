{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Narview",
  "version": "0.1.0-rc.13",
  "identifier": "com.resplendentdata.narview",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Narview",
        "label": "main",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "appimage"],
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY5RDMxMDBFOTgwQjEwNEMKUldSTUVBdVlEaERUK1JWVlVsZ24zNC9OejFyZnkrQ3pDbmFETUhxYVZrTHlDTUdGMTRacmVEWnYK",
      "endpoints": ["https://github.com/Resplendent-Data/Narview/releases/latest/download/latest.json"]
    }
  }
}
