{
  "name": "narview-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/desktop",
    "packages/contracts"
  ],
  "scripts": {
    "dev": "npm run desktop:dev",
    "build": "npm run desktop:build",
    "test": "npm run desktop:test",
    "test:v1-acceptance": "npm --workspace apps/desktop run test:v1-acceptance",
    "test:release-config": "npm --workspace apps/desktop run test:release-config",
    "test:smoke": "npm --workspace apps/desktop run test:smoke",
    "tauri": "npm run desktop:tauri",
    "tauri:dev": "npm run desktop:tauri:dev",
    "desktop:dev": "npm --workspace apps/desktop run dev",
    "desktop:build": "npm --workspace apps/desktop run build",
    "desktop:test": "npm --workspace apps/desktop run test",
    "desktop:test:smoke": "npm --workspace apps/desktop run test:smoke",
    "desktop:tauri": "npm --workspace apps/desktop run tauri",
    "desktop:tauri:dev": "npm --workspace apps/desktop run tauri:dev",
    "mobile:test": "cd apps/mobile && flutter test",
    "mobile:analyze": "cd apps/mobile && flutter analyze"
  }
}
